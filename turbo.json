{
  "$schema": "https://turbo.build/json-schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "*.tgz"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": true
    },
    "coverage": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "check-types": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "lint": {
      "cache": true,
      "outputs": [".eslintcache"]
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "precommit": {
      "dependsOn": ["check-types"],
      "cache": false
    }
  }
}
