{
  "name": "@agentsy/monorepo",
  "version": "0.1.1",
  "private": true,
  "description": "Agentsy agentic development framework",
  "keywords": [
    "agentic",
    "agentic-ai",
    "agentic-framework",
    "agentic-workflow",
    "agents",
    "ai",
    "anthropic",
    "chatbot",
    "chatgpt",
    "json",
    "llm",
    "mistral",
    "models",
    "ollama",
    "openai",
    "parser",
    "xml"
  ],
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "docs:build": "vitepress build",
    "docs:dev": "vitepress dev",
    "docs:preview": "vitepress preview",
    "check-types": "turbo run check-types",
    "fallow": "fallow",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "test": "turbo run test",
    "test:release": "pnpm -C packages/scripts run release-test",
    "test:coverage": "turbo run coverage",
    "precommit": "turbo run precommit",
    "release": "pnpm -C packages/scripts run release",
    "bootstrap-release": "pnpm -C packages/scripts run bootstrap-release",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "fallow": "^2.74.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "tsx": "^4.22.0",
    "turbo": "^2.9.14",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --no-error-on-unmatched-pattern .",
      "oxfmt --no-error-on-unmatched-pattern --write ."
    ],
    "**/*.{json,md,yaml,yml}": [
      "oxfmt --no-error-on-unmatched-pattern --write ."
    ]
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@go-task/cli",
      "es5-ext",
      "esbuild",
      "fallow",
      "msw"
    ]
  }
}
