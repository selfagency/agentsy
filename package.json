{
  "name": "@selfagency/llm-stream-parser",
  "version": "0.2.0",
  "description": "Composable parsers and stream processing utilities for LLM responses",
  "keywords": [
    "ai",
    "anthropic",
    "gemini",
    "json",
    "llm",
    "mistral",
    "openai",
    "parser",
    "streaming",
    "tools",
    "xml"
  ],
  "homepage": "https://llmstreamparser.self.agency",
  "bugs": {
    "url": "https://github.com/selfagency/llm-stream-parser/issues"
  },
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/llm-stream-parser.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
