{
  "name": "@agentsy/monorepo",
  "version": "0.1.0",
  "type": "module",
  "description": "Monorepo for Agentsy agentic development framework",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "test": "turbo run test",
    "test:release": "node --test scripts/release-state.test.js scripts/trusted-publish-readiness.test.js",
    "test:coverage": "turbo run test:coverage",
    "precommit": "turbo run precommit",
    "release": "pnpm exec zx scripts/release-per-package.js",
    "bootstrap-release": "pnpm exec zx scripts/bootstrap-release.js"
  },
  "devDependencies": {
    "@octokit/rest": "22.0.1",
    "@types/node": "^25.6.0",
    "ora": "9.4.0",
    "turbo": "^2.9.8",
    "zx": "^8.8.5"
  },
  "keywords": [
    "ai",
    "anthropic",
    "gemini",
    "json",
    "llm",
    "mistral",
    "openai",
    "parser",
    "streaming",
    "tools",
    "xml"
  ],
  "author": "Daniel Sieradski <daniel@self.agency>",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2"
}