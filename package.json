  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "test": "vitest run src",
    "themes:preview": "node scripts/preview-themes.js",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview"
  },
  "devDependencies": {
    "@go-task/cli": "^3.50.0",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.5",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ora": "^9.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vite": "^8.0.10",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "zx": "^8.8.5"
  },
  "peerDependencies": {
    "@ag-ui/core": "^0.0.53",
    "ink": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "ink": {
