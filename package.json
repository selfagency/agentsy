{
  "name": "@agentsy/monorepo",
  "version": "0.1.1",
  "private": true,
  "description": "Agentsy agentic development framework",
  "keywords": [
    "agentic",
    "agentic-ai",
    "agentic-framework",
    "agentic-workflow",
    "agents",
    "ai",
    "anthropic",
    "chatbot",
    "chatgpt",
    "json",
    "llm",
    "mistral",
    "models",
    "ollama",
    "openai",
    "parser",
    "xml"
  ],
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "docs:build": "vitepress build",
    "docs:dev": "vitepress dev",
    "docs:preview": "vitepress preview",
    "check-types": "turbo run check-types",
    "fallow": "fallow",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "test": "turbo run test",
    "test:release": "pnpm -C packages/scripts run release-test",
    "test:coverage": "turbo run coverage",
    "precommit": "turbo run precommit",
    "release": "pnpm -C packages/scripts run release",
    "bootstrap-release": "pnpm -C packages/scripts run bootstrap-release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@octokit/rest": "22.0.1",
    "@types/node": "^25.7.0",
    "fallow": "^2.73.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ora": "^9.4.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6",
    "zod-to-json-schema": "^3.25.2",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --no-error-on-unmatched-pattern .",
      "oxfmt --no-error-on-unmatched-pattern --write ."
    ],
    "**/*.{json,md,yaml,yml}": [
      "oxfmt --no-error-on-unmatched-pattern --write ."
    ]
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@go-task/cli",
      "esbuild",
      "fallow"
    ]
  }
}
