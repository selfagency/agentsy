{
  "name": "@agentsy/monorepo",
  "version": "0.1.1",
  "private": true,
  "description": "Agentsy agentic development framework",
  "keywords": [
    "agentic",
    "agentic-ai",
    "agentic-framework",
    "agentic-workflow",
    "agents",
    "ai",
    "anthropic",
    "chatbot",
    "chatgpt",
    "json",
    "llm",
    "mistral",
    "models",
    "ollama",
    "openai",
    "parser",
    "xml"
  ],
  "license": "GPL-3.0-or-later",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "type": "module",
  "scripts": {
    "bootstrap-release": "pnpm -C packages/scripts run bootstrap-release",
    "build": "turbo run build",
    "check": "ultracite check",
    "check-types": "turbo run check-types",
    "docs:build": "vitepress build",
    "docs:dev": "vitepress dev",
    "docs:preview": "vitepress preview",
    "fallow": "fallow",
    "fix": "ultracite fix",
    "format": "rumdl fmt && turbo run format",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --write",
    "precommit": "turbo run precommit",
    "prepare": "husky",
    "release": "pnpm -C packages/scripts run release",
    "test": "turbo run test",
    "test:coverage": "turbo run coverage",
    "test:release": "pnpm -C packages/scripts run release-test"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,md,yaml,yml,cjs,mjs,css,scss,jsonc,mdx}": [
      "ultracite fix"
    ],
    "**/*.{md,mdx}": [
      "rumdl fmt"
    ]
  },
  "dependencies": {
    "@oclif/core": "^4.11.3",
    "@opentelemetry/api": "^1.9.1",
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@microsoft/tui-test": "^0.0.4",
    "@types/node": "^25.9.0",
    "fallow": "^2.75.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.22.2",
    "turbo": "^2.9.14",
    "ultracite": "7.8.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "es5-ext",
      "esbuild",
      "fallow",
      "msw",
      "node-pty"
    ],
    "overrides": {
      "vite": "^7.0.0"
    }
  }
}
