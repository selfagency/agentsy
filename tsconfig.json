{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDir": "./",
    "outDir": "./dist",
    "module": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@agentsy/context": ["packages/context/src/index.ts"],
      "@agentsy/models": ["packages/models/src/index.ts"],
      "@agentsy/models/local-providers": [
        "packages/models/src/local-providers/index.ts"
      ],
      "@agentsy/models/search-contracts": [
        "packages/models/src/search-contracts.ts"
      ],
      "@agentsy/types": ["packages/types/src/index.ts"]
    },
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true
  },
  "include": ["**/src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
