{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDir": "./",
    "outDir": "./dist",
    "module": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@agentsy/context": ["packages/context/src/index.ts"],
      "@agentsy/connectors": ["packages/connectors/src/index.ts"],
      "@agentsy/guardrails": ["packages/guardrails/src/index.ts"],
      "@agentsy/models": ["packages/models/src/index.ts"],
      "@agentsy/models/local-providers": [
        "packages/models/src/local-providers/index.ts"
      ],
      "@agentsy/models/search-contracts": [
        "packages/models/src/search-contracts.ts"
      ],
      "@agentsy/observability": ["packages/observability/src/index.ts"],
      "@agentsy/observability/*": ["packages/observability/src/*"],
      "@agentsy/mcp": ["packages/mcp/src/index.ts"],
      "@agentsy/memory": ["packages/memory/src/index.ts"],
      "@agentsy/memory/*": ["packages/memory/src/*"],
      "@agentsy/secrets": ["packages/secrets/src/index.ts"],
      "@agentsy/session": ["packages/session/src/index.ts"],
      "@agentsy/session/*": ["packages/session/src/*"],
      "@agentsy/shared": ["packages/shared/src/index.ts"],
      "@agentsy/shared/*": ["packages/shared/src/*"],
      "@agentsy/tokenomics": ["packages/tokenomics/src/index.ts"],
      "@agentsy/tools": ["packages/tools/src/index.ts"],
      "@agentsy/tools/*": ["packages/tools/src/*"],
      "@agentsy/types": ["packages/types/src/index.ts"]
    },
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true
  },
  "include": ["**/src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
