# @agentsy Monorepo Configuration

# npm organization scope
agentsy:registry=https://registry.npmjs.org/@agentsy

# Always verify authenticity of packages
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Workspace management
package-lock=false
sharp-linux-prebuilt-glibc=false
prefer-offline=false

# Build integrity
disable-progress=true
save-prefix="^"
save-exact=false

# Registry preferences
registry=https://registry.npmjs.org

# Node.js 22 target
engine-strict=true
strict-peer-dependencies=false
strict-peer-dependencies