# @agentsy Monorepo Configuration

# npm organization scope
@agentsy:registry=https://registry.npmjs.org/

# Always verify authenticity of packages
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Workspace management
prefer-offline=false

# Build integrity
save-prefix=^
save-exact=false

# Registry preferences
registry=https://registry.npmjs.org

# Node.js 22 target
engine-strict=true
