{
  "name": "@agentsy/memory",
  "version": "0.0.0",
  "description": "Three-layer memory engine (raw event log, synthesized wiki, vector retrieval)",
  "keywords": [
    "agentsy",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "bin": {
    "agentsy-memory": "./bin/run.js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cognitive": {
      "types": "./dist/cognitive.d.ts",
      "import": "./dist/cognitive.js",
      "require": "./dist/cognitive.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js",
      "require": "./dist/hooks.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@agentsy/context": "workspace:*",
    "@agentsy/types": "workspace:*",
    "@oclif/core": "^4.11.4",
    "@tursodatabase/sync": "^0.6.1",
    "better-sqlite3": "^12.1.0",
    "blake3-jit": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.8",
    "msw": "^2.14.6",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "oclif": {
    "bin": "agentsy-memory",
    "commands": "./dist/commands",
    "dirname": "dist",
    "topicSeparator": ":"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2"
}
