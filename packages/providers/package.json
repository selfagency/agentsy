{
  "name": "@agentsy/providers",
  "version": "0.2.0",
  "description": "Provider abstraction layer for adapters, normalizers, universal clients, and provider capabilities",
  "keywords": [
    "adapters",
    "agentsy",
    "normalizers",
    "providers",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git",
    "directory": "packages/providers"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js",
      "require": "./dist/adapters.cjs"
    },
    "./normalizers": {
      "types": "./dist/normalizers.d.ts",
      "import": "./dist/normalizers.js",
      "require": "./dist/normalizers.cjs"
    },
    "./pipeline": {
      "types": "./dist/pipeline.d.ts",
      "import": "./dist/pipeline.js",
      "require": "./dist/pipeline.cjs"
    },
    "./request-path": {
      "types": "./dist/request-path.d.ts",
      "import": "./dist/request-path.js",
      "require": "./dist/request-path.cjs"
    },
    "./universal-client": {
      "types": "./dist/universal-client.d.ts",
      "import": "./dist/universal-client.js",
      "require": "./dist/universal-client.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2"
}
