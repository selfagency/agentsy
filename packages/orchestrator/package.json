{
  "name": "@agentsy/orchestrator",
  "version": "0.2.0-alpha.0",
  "description": "Advanced agent orchestration system with consolidated scheduler",
  "keywords": [
    "agentsy",
    "orchestration",
    "scheduler",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git",
    "directory": "packages/orchestrator"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "require": "./dist/agent/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "format": "oxfmt --no-error-on-unmatched-pattern --write ."
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/memory": "workspace:*",
    "@agentsy/runtime": "workspace:*",
    "@agentsy/types": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.64.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
