{
  "name": "@agentsy/orchestrator",
  "version": "0.2.0-alpha.0",
  "description": "Advanced agent orchestration system with consolidated scheduler",
  "keywords": [
    "agentsy",
    "orchestration",
    "scheduler",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git",
    "directory": "packages/orchestrator"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "require": "./dist/agent/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format"
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/gateway": "workspace:*",
    "@agentsy/memory": "workspace:*",
    "@agentsy/observability": "workspace:*",
    "@agentsy/runtime": "workspace:*",
    "@agentsy/types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
