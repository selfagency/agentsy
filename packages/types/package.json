{
  "name": "@agentsy/types",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Shared TypeScript types for the @agentsy/* package family.",
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "homepage": "https://agentsy.self.agency",
  "bugs": {
    "url": "https://github.com/selfagency/agentsy/issues"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "test": "vitest --typecheck run",
    "coverage": "vitest --typecheck run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "type-fest": "5.6.0"
  },
  "packageManager": "pnpm@10.33.2"
}