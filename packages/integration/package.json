{
  "name": "@agentsy/integration",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-package integration tests for the @agentsy/* family",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@agentsy/adapters": "workspace:*",
    "@agentsy/context": "workspace:*",
    "@agentsy/formatting": "workspace:*",
    "@agentsy/normalizers": "workspace:*",
    "@agentsy/processor": "workspace:*",
    "@agentsy/recovery": "workspace:*",
    "@agentsy/renderers": "workspace:*",
    "@agentsy/sse": "workspace:*",
    "@agentsy/structured": "workspace:*",
    "@agentsy/thinking": "workspace:*",
    "@agentsy/tool-calls": "workspace:*",
    "@agentsy/types": "workspace:*",
    "@agentsy/xml-filter": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
