{
  "name": "@agentsy/core",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Foundation stream parsing layer for Agentsy agentic development framework: thinking extraction, XML filtering, tool-call routing, JSON validation, provider normalization.",
  "keywords": [
    "ai",
    "anthropic",
    "gemini",
    "json",
    "llm",
    "mistral",
    "openai",
    "parser",
    "streaming",
    "tools",
    "xml"
  ],
  "homepage": "https://agentsy.self.agency",
  "bugs": {
    "url": "https://github.com/selfagency/agentsy/issues"
  },
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js",
      "require": "./dist/context/index.cjs"
    },
    "./formatting": {
      "types": "./dist/formatting/index.d.ts",
      "import": "./dist/formatting/index.js",
      "require": "./dist/formatting/index.cjs"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.ts",
      "import": "./dist/markdown/index.js",
      "require": "./dist/markdown/index.cjs"
    },
    "./normalizers": {
      "types": "./dist/normalizers/index.d.ts",
      "import": "./dist/normalizers/index.js",
      "require": "./dist/normalizers/index.cjs"
    },
    "./recovery": {
      "types": "./dist/recovery/index.d.ts",
      "import": "./dist/recovery/index.js",
      "require": "./dist/recovery/index.cjs"
    },
    "./sse": {
      "types": "./dist/sse/index.d.ts",
      "import": "./dist/sse/index.js",
      "require": "./dist/sse/index.cjs"
    },
    "./renderers": {
      "types": "./dist/renderers/index.d.ts",
      "import": "./dist/renderers/index.js",
      "require": "./dist/renderers/index.cjs"
    },
    "./renderers/plain": {
      "types": "./dist/renderers/plain/index.d.ts",
      "import": "./dist/renderers/plain/index.js",
      "require": "./dist/renderers/plain/index.cjs"
    },
    "./renderers/cli": {
      "types": "./dist/renderers/cli/index.d.ts",
      "import": "./dist/renderers/cli/index.js",
      "require": "./dist/renderers/cli/index.cjs"
    },
    "./renderers/streaming-md": {
      "types": "./dist/renderers/streaming-md/index.d.ts",
      "import": "./dist/renderers/streaming-md/index.js",
      "require": "./dist/renderers/streaming-md/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    },
    "./renderers/ink": {
      "types": "./dist/renderers/ink/index.d.ts",
      "import": "./dist/renderers/ink/index.js",
      "require": "./dist/renderers/ink/index.cjs"
    }
  },
  "dependencies": {
    "@agentsy/normalizers": "workspace:*",
    "@agentsy/processor": "workspace:*",
    "@agentsy/tool-calls": "workspace:*",
    "@agentsy/types": "workspace:*",
    "@agentsy/xml-filter": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "test": "vitest run src",
    "coverage": "vitest run src --coverage",
    "themes:preview": "node scripts/preview-themes.js",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview"
  },
  "devDependencies": {
    "@agentsy/processor": "workspace:*",
    "@go-task/cli": "^3.50.0",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.5",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^16.4.0",
    "ora": "^9.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vite": "^8.0.10",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "zx": "^8.8.5"
  },
  "peerDependencies": {
    "@ag-ui/core": "^0.0.53",
    "ink": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "ink": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "cli-markdown": "^3.5.1"
  },
  "packageManager": "pnpm@10.31.0"
}