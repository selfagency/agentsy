{
  "name": "@agentsy/processor",
  "version": "0.1.0",
  "description": "LLM stream processor with chunking, normalization, and event handling",
  "keywords": [
    "agent",
    "llm",
    "normalization",
    "pipeline",
    "processor",
    "stream"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentsy/normalizers": "workspace:*",
    "@agentsy/structured": "workspace:*",
    "@agentsy/thinking": "workspace:*",
    "@agentsy/tool-calls": "workspace:*",
    "@agentsy/types": "workspace:*",
    "@agentsy/xml-filter": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {}
}
