{
  "name": "@agentsy/cli",
  "version": "0.0.0",
  "description": "@agentsy cli package",
  "keywords": [
    "agentsy",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/memory": "workspace:*",
    "@agentsy/runtime": "workspace:*",
    "@agentsy/tokens": "workspace:*",
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
