{
  "name": "@agentsy/tools",
  "version": "0.2.0-alpha.0",
  "description": "Tool implementations including REPL (consolidated: repl)",
  "keywords": [
    "agentsy",
    "repl",
    "tools",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cortexkit": {
      "types": "./dist/cortexkit/import-linter.d.ts",
      "import": "./dist/cortexkit/import-linter.js",
      "require": "./dist/cortexkit/import-linter.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@agentsy/shared": "workspace:*",
    "@agentsy/types": "workspace:*",
    "@cortexkit/aft-bridge": "^0.37.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
