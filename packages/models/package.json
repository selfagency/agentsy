{
  "name": "@agentsy/models",
  "version": "0.1.0",
  "description": "Model selection and provider metadata from models.dev",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./llm-stats-client": {
      "import": "./dist/llm-stats-client.js",
      "require": "./dist/llm-stats-client.cjs",
      "types": "./dist/llm-stats-client.d.ts"
    },
    "./search-contracts": {
      "import": "./dist/search-contracts.js",
      "require": "./dist/search-contracts.cjs",
      "types": "./dist/search-contracts.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest --run --passWithNoTests",
    "lint": "biome lint",
    "format": "biome format"
  },
  "dependencies": {
    "@agentsy/types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsup": "^8.3.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
