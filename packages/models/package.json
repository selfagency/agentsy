{
  "name": "@agentsy/models",
  "version": "0.1.0",
  "description": "Model selection and provider metadata from models.dev",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run --passWithNoTests",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "format": "oxfmt --no-error-on-unmatched-pattern --write ."
  },
  "dependencies": {
    "@agentsy/types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.3.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  }
}
