{
  "name": "@agentsy/plugins",
  "version": "0.0.0",
  "description": "@agentsy plugins package",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "format": "oxfmt --no-error-on-unmatched-pattern --write .",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup":    "tsup":    "tsup":    "tsup": 3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
