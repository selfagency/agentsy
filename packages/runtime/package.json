{
  "name": "@agentsy/runtime",
  "version": "0.0.0",
  "description": "Agent runtime orchestration",
  "keywords": [
    "agentsy",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ag-ui": {
      "types": "./dist/ag-ui.d.ts",
      "import": "./dist/ag-ui.js",
      "require": "./dist/ag-ui.cjs"
    },
    "./approval": {
      "types": "./dist/approval.d.ts",
      "import": "./dist/approval.js",
      "require": "./dist/approval.cjs"
    },
    "./loop": {
      "types": "./dist/loop.d.ts",
      "import": "./dist/loop.js",
      "require": "./dist/loop.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@agentsy/context": "workspace:*",
    "@agentsy/guardrails": "workspace:*",
    "@agentsy/memory": "workspace:*",
    "@agentsy/session": "workspace:*",
    "@agentsy/types": "workspace:*",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
