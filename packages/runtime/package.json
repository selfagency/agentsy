{
  "name": "@agentsy/runtime",
  "version": "0.0.0",
  "description": "Agent runtime orchestration",
  "keywords": [
    "agentsy",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ag-ui": {
      "types": "./dist/ag-ui/index.d.ts",
      "import": "./dist/ag-ui/index.js",
      "require": "./dist/ag-ui/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@agentsy/memory": "workspace:*",
    "@agentsy/session": "workspace:*",
    "@agentsy/types": "workspace:*",
    "tsx": "^4.22.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2"
}
