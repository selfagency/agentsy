{
  "name": "@agentsy/retrieval",
  "version": "0.1.0",
  "description": "Information specialist for RAG - multi-modal indexing, hybrid search, and context retrieval",
  "keywords": [
    "agentsy",
    "embedding",
    "indexing",
    "rag",
    "retrieval",
    "search",
    "sql",
    "vector"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git",
    "directory": "packages/retrieval"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage",
    "lint": "oxlint .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2"
}
