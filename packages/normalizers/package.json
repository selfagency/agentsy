{
  "name": "@agentsy/normalizers",
  "version": "0.1.0",
  "private": false,
  "description": "Provider-specific LLM stream normalizers for the @agentsy platform.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "format": "oxfmt --no-error-on-unmatched-pattern --write .",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
