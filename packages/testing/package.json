{
  "name": "@agentsy/testing",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-package integration tests and shared test harness for the @agentsy/* family",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "type": "module",
  "scripts": {
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "coverage": "vitest --run --coverage",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format"
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/memory": "workspace:*",
    "@agentsy/observability": "workspace:*",
    "@agentsy/providers": "workspace:*",
    "@agentsy/renderers": "workspace:*",
    "@agentsy/session": "workspace:*",
    "@agentsy/shared": "workspace:*",
    "@agentsy/tools": "workspace:*",
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@copilotkit/aimock": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.8",
    "msw": "^2.14.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.19.6"
  }
}
