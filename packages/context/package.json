{
  "name": "@agentsy/context",
  "version": "0.2.2",
  "description": "Compression, drift detection, and reversible output shaping",
  "keywords": [
    "agentsy",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git",
    "directory": "packages/context"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage"
  },
  "peerDependencies": {
    "@agentsy/core": "^0.2.0",
    "@agentsy/tokenomics": "workspace:*",
    "@agentsy/types": "^0.1.1"
  },
  "peerDependenciesMeta": {
    "@agentsy/core": {
      "optional": false
    },
    "@agentsy/tokenomics": {
      "optional": false
    },
    "@agentsy/types": {
      "optional": false
    }
  },
  "devDependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/tokenomics": "workspace:*",
    "@agentsy/types": "workspace:*",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2"
}
