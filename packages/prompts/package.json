{
  "name": "@agentsy/prompts",
  "version": "0.1.0",
  "description": "Prompt optimization and agentic pattern management for @agentsy",
  "keywords": [
    "agentic",
    "guardrails",
    "optimization",
    "prompt",
    "reasoning"
  ],
  "license": "GPL-3.0-or-later",
  "author": "Agentsy Contributors",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage",
    "lint": "biome lint",
    "format": "biome format"
  },
  "dependencies": {
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  }
}
