{
  "name": "@agentsy/renderers",
  "version": "0.1.2",
  "private": false,
  "description": "Composable output renderers for the @agentsy platform.",
  "keywords": [
    "agentsy",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "format": "oxfmt --no-error-on-unmatched-pattern --write .",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.5",
    "chalk": "^5.6.2",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "ink": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "ink": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "cli-markdown": "^3.5.1"
  },
  "packageManager": "pnpm@10.33.2"
}
