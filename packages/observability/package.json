{
  "name": "@agentsy/observability",
  "version": "0.0.0",
  "description": "AI Agent Observability Platform with OpenTelemetry tracing, metrics, and conversation recording",
  "keywords": [
    "agentsy",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./instrumentation": {
      "types": "./dist/instrumentation.d.ts",
      "import": "./dist/instrumentation.js",
      "require": "./dist/instrumentation.cjs"
    },
    "./exporters": {
      "types": "./dist/exporters.d.ts",
      "import": "./dist/exporters.js",
      "require": "./dist/exporters.cjs"
    },
    "./spans": {
      "types": "./dist/spans.d.ts",
      "import": "./dist/spans.js",
      "require": "./dist/spans.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format",
    "test": "vitest --run --passWithNoTests",
    "coverage": "vitest --run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@agentsy/types": "workspace:*",
    "@opentelemetry/api": "^1.9.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2"
}
