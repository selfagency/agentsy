{
  "name": "@agentsy/vscode",
  "version": "0.1.1",
  "private": false,
  "description": "Unified VS Code integration library for Language Model Chat Providers",
  "keywords": [
    "chat-provider",
    "copilot",
    "language-model",
    "llm",
    "streaming",
    "vscode"
  ],
  "homepage": "https://github.com/selfagency/agentsy#readme",
  "license": "MIT",
  "author": "Selfagency",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js",
      "require": "./dist/renderer/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.cjs"
    },
    "./mcp-integration": {
      "types": "./dist/mcp-integration/index.d.ts",
      "import": "./dist/mcp-integration/index.js",
      "require": "./dist/mcp-integration/index.cjs"
    },
    "./retry": {
      "types": "./dist/retry/index.d.ts",
      "import": "./dist/retry/index.js",
      "require": "./dist/retry/index.cjs"
    },
    "./stream-bridge": {
      "types": "./dist/stream-bridge/index.d.ts",
      "import": "./dist/stream-bridge/index.js",
      "require": "./dist/stream-bridge/index.cjs"
    },
    "./vscode-overloads": {
      "types": "./dist/vscode-overloads/index.d.ts",
      "import": "./dist/vscode-overloads/index.js",
      "require": "./dist/vscode-overloads/index.cjs"
    },
    "./api-key-manager": {
      "types": "./dist/api-key-manager/index.d.ts",
      "import": "./dist/api-key-manager/index.js",
      "require": "./dist/api-key-manager/index.cjs"
    },
    "./settings": {
      "types": "./dist/settings/index.d.ts",
      "import": "./dist/settings/index.js",
      "require": "./dist/settings/index.cjs"
    },
    "./error-handling": {
      "types": "./dist/error-handling/index.d.ts",
      "import": "./dist/error-handling/index.js",
      "require": "./dist/error-handling/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "format": "oxfmt --no-error-on-unmatched-pattern --write .",
    "format:check": "oxfmt --no-error-on-unmatched-pattern --check .",
    "precommit": "npm run check-types && npm run lint && npm run format:check"
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/providers": "workspace:*",
    "@agentsy/renderers": "workspace:*",
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.118.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
