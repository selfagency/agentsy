    "@types/vscode": "^1.93.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
