{
  "name": "@agentsy/vscode",
  "version": "0.1.0-beta.1",
  "description": "Unified VS Code integration library for Language Model Chat Providers with llm-stream-parser 0.3.1 support",
  "keywords": [
    "vscode",
    "language-model",
    "chat-provider",
    "llm",
    "copilot",
    "streaming"
  ],
  "license": "MIT",
  "author": "Selfagency",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
