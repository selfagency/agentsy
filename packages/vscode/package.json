{
  "name": "@agentsy/vscode",
  "version": "0.1.1",
  "private": false,
  "description": "Unified VS Code integration library for Language Model Chat Providers",
  "keywords": [
    "chat-provider",
    "copilot",
    "language-model",
    "llm",
    "streaming",
    "vscode"
  ],
  "license": "MIT",
  "author": "Selfagency",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/agentsy.git"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./api-key-manager": {
      "types": "./dist/api-key-manager.d.ts",
      "import": "./dist/api-key-manager.js",
      "require": "./dist/api-key-manager.cjs"
    },
    "./stream-bridge": {
      "types": "./dist/stream-bridge.d.ts",
      "import": "./dist/stream-bridge.js",
      "require": "./dist/stream-bridge.cjs"
    },
    "./vscode-renderer": {
      "types": "./dist/vscode-renderer.d.ts",
      "import": "./dist/vscode-renderer.js",
      "require": "./dist/vscode-renderer.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    },
    "./message-conversion": {
      "types": "./dist/message-conversion.d.ts",
      "import": "./dist/message-conversion.js",
      "require": "./dist/message-conversion.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "coverage": "vitest --run --coverage",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "precommit": "pnpm run check-types && pnpm run lint && pnpm run format:check"
  },
  "dependencies": {
    "@agentsy/core": "workspace:*",
    "@agentsy/providers": "workspace:*",
    "@agentsy/renderers": "workspace:*",
    "@agentsy/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/vscode": "^1.120.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
